[Unit]
Description=Bilibili Topic Analyzer Web
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/bilibilitopic
Environment=HOST=127.0.0.1
Environment=PORT=8000
Environment=BASE_PATH=/btopic
ExecStart=/opt/bilibilitopic/.venv/bin/uvicorn web.app:application --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
