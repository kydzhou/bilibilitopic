[Unit]
Description=Bilibili Topic Analyzer Web
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/bilibilitopic
EnvironmentFile=/opt/bilibilitopic/.env
Environment=HOST=127.0.0.1
Environment=PORT=8000
ExecStart=/opt/bilibilitopic/.venv/bin/uvicorn web.app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
